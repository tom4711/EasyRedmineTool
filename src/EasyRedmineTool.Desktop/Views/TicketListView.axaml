<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    x:Class="EasyRedmineTool.Desktop.Views.TicketListView"
    x:DataType="vm:TicketListViewModel">

  <StackPanel Margin="24" Spacing="12">
    <TextBlock Text="Meine offenen Tickets" FontSize="22" FontWeight="Bold" />

    <Button Content="Tickets laden" Command="{Binding LoadTicketsCommand}" />

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBox Width="180" Watermark="Ticket-ID" Text="{Binding TicketIdToAdd}" />
      <Button Content="Ticket per ID hinzufügen" Command="{Binding AddTicketByIdCommand}" />
    </StackPanel>

    <TextBlock Text="Favorit direkt je Ticket über ⭐ in der Liste setzen/entfernen." />
    <Button Content="Favorit für ausgewähltes Ticket umschalten" Command="{Binding ToggleSelectedFavoriteCommand}" />
    <TextBlock Text="{Binding IsSelectedFavorite, StringFormat=Ausgewähltes Ticket Favorit: {0}}" />

    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />

    <ListBox ItemsSource="{Binding Tickets}" SelectedItem="{Binding SelectedTicket}" Height="300">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Padding="8" Margin="0,0,0,8">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Id, StringFormat=#\{0\}}" FontWeight="Bold" />
              <Button Grid.Row="0"
                      Grid.Column="1"
                      Content="⭐"
                      ToolTip.Tip="Favorit setzen/entfernen"
                      Command="{Binding $parent[UserControl].DataContext.ToggleFavoriteForTicketCommand}"
                      CommandParameter="{Binding .}" />
              <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Subject}" TextWrapping="Wrap" />
              <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Project.Name, StringFormat=Projekt: {0}}" />
              <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Status.Name, StringFormat=Status: {0}}" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </StackPanel>
</UserControl>
