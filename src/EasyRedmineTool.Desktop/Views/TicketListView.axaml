<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    x:Class="EasyRedmineTool.Desktop.Views.TicketListView"
    x:DataType="vm:TicketListViewModel">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="TicketItemBorderBrush" Color="#E0E0E0" />
          <SolidColorBrush x:Key="TicketFavoriteBackgroundBrush" Color="#FFF8E1" />
          <SolidColorBrush x:Key="TicketFavoriteBorderBrush" Color="#F5A623" />
          <SolidColorBrush x:Key="TicketFavoriteStarActiveBrush" Color="#F5A623" />
          <SolidColorBrush x:Key="TicketFavoriteStarInactiveBrush" Color="#BDBDBD" />
          <SolidColorBrush x:Key="TicketFavoriteBadgeBackgroundBrush" Color="#F5A623" />
          <SolidColorBrush x:Key="TicketFavoriteBadgeForegroundBrush" Color="White" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="TicketItemBorderBrush" Color="#525252" />
          <SolidColorBrush x:Key="TicketFavoriteBackgroundBrush" Color="#3D3220" />
          <SolidColorBrush x:Key="TicketFavoriteBorderBrush" Color="#D4A017" />
          <SolidColorBrush x:Key="TicketFavoriteStarActiveBrush" Color="#FFB74D" />
          <SolidColorBrush x:Key="TicketFavoriteStarInactiveBrush" Color="#757575" />
          <SolidColorBrush x:Key="TicketFavoriteBadgeBackgroundBrush" Color="#D4A017" />
          <SolidColorBrush x:Key="TicketFavoriteBadgeForegroundBrush" Color="#1A1408" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.ticket-item">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource TicketItemBorderBrush}" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Border.ticket-item.favorite">
      <Setter Property="Background" Value="{DynamicResource TicketFavoriteBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TicketFavoriteBorderBrush}" />
    </Style>
    <Style Selector="TextBlock.favorite-star">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.favorite-star.active">
      <Setter Property="Foreground" Value="{DynamicResource TicketFavoriteStarActiveBrush}" />
    </Style>
    <Style Selector="TextBlock.favorite-star.inactive">
      <Setter Property="Foreground" Value="{DynamicResource TicketFavoriteStarInactiveBrush}" />
    </Style>
    <Style Selector="Border.favorite-badge">
      <Setter Property="Background" Value="{DynamicResource TicketFavoriteBadgeBackgroundBrush}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="6,2" />
    </Style>
    <Style Selector="TextBlock.favorite-badge-text">
      <Setter Property="Foreground" Value="{DynamicResource TicketFavoriteBadgeForegroundBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Margin="24,24,24,12" Spacing="12">
      <TextBlock Text="Meine Tickets" FontSize="22" FontWeight="Bold" />

      <Button Classes="primary"
              Content="Tickets laden"
              Command="{Binding LoadTicketsCommand}" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Width="180" PlaceholderText="Ticket-ID" Text="{Binding TicketIdToAdd}" />
        <Button Classes="secondary"
                Content="Ticket per ID hinzufügen"
                Command="{Binding AddTicketByIdCommand}" />
      </StackPanel>

      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
    </StackPanel>

    <ListBox Grid.Row="1"
             Margin="24,0,24,24"
             ItemsSource="{Binding Tickets}"
             SelectedItem="{Binding SelectedTicket}">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:TicketListItemViewModel">
          <Border Classes="ticket-item"
                  Classes.favorite="{Binding IsFavorite}"
                  Padding="8"
                  Margin="0,0,0,8">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
              <StackPanel Grid.Row="0"
                          Grid.Column="0"
                          Orientation="Horizontal"
                          Spacing="8">
                <TextBlock Text="{Binding Ticket.Id, StringFormat=#\{0\}}" FontWeight="Bold" />
                <Border Classes="favorite-badge" IsVisible="{Binding IsFavorite}">
                  <TextBlock Classes="favorite-badge-text" Text="Favorit" />
                </Border>
              </StackPanel>

              <Button Grid.Row="0"
                      Grid.Column="1"
                      Classes="ghost"
                      ToolTip.Tip="Favorit setzen/entfernen"
                      Command="{Binding $parent[UserControl].DataContext.ToggleFavoriteForTicketCommand}"
                      CommandParameter="{Binding .}">
                <Panel>
                  <TextBlock Classes="favorite-star active"
                             Text="★"
                             IsVisible="{Binding IsFavorite}" />
                  <TextBlock Classes="favorite-star inactive"
                             Text="☆"
                             IsVisible="{Binding !IsFavorite}" />
                </Panel>
              </Button>

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Grid.ColumnSpan="2"
                         Text="{Binding Ticket.Subject}"
                         TextWrapping="Wrap" />
              <TextBlock Grid.Row="2"
                         Grid.Column="0"
                         Grid.ColumnSpan="2"
                         Text="{Binding Ticket.Project.Name, StringFormat=Projekt: {0}}" />
              <TextBlock Grid.Row="3"
                         Grid.Column="0"
                         Grid.ColumnSpan="2"
                         Text="{Binding Ticket.Status.Name, StringFormat=Status: {0}}" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
