<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="EasyRedmineTool.Desktop.Views.TicketListView"
    x:DataType="vm:TicketListViewModel">
  <UserControl.Styles>
    <Style Selector="Border.ticket-item">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Border.ticket-item.favorite">
      <Setter Property="Background" Value="{DynamicResource TicketFavoriteBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TicketFavoriteBorderBrush}" />
    </Style>
    <Style Selector="mi|MaterialIcon.favorite-star">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
    </Style>
    <Style Selector="mi|MaterialIcon.favorite-star.active">
      <Setter Property="Foreground" Value="{DynamicResource TicketFavoriteStarActiveBrush}" />
    </Style>
    <Style Selector="mi|MaterialIcon.favorite-star.inactive">
      <Setter Property="Foreground" Value="{DynamicResource TicketFavoriteStarInactiveBrush}" />
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="Border.favorite-badge">
      <Setter Property="Background" Value="{DynamicResource TicketFavoriteBadgeBackgroundBrush}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="6,2" />
    </Style>
    <Style Selector="TextBlock.favorite-badge-text">
      <Setter Property="Foreground" Value="{DynamicResource TicketFavoriteBadgeForegroundBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.ticket-meta">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Opacity" Value="0.85" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.ticket-extra">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.7" />
    </Style>
    <Style Selector="Border.filter-card">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="TextBlock.filter-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.7" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="ComboBox.filter-field">
      <Setter Property="MinWidth" Value="180" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.filter-date-picker">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="MinWidth" Value="180" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Margin="24,24,24,12" Spacing="12">
      <TextBlock Text="Meine Tickets" FontSize="22" FontWeight="Bold" />

      <Border Classes="filter-card"
              Padding="16"
              HorizontalAlignment="Stretch">
        <StackPanel Spacing="12">
          <TextBlock Text="Lade-Filter"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="Standardmäßig werden nur Tickets nach Zuweisung und Status geladen. Fehlende Tickets können per ID ergänzt werden. Optional lassen sich zusätzliche Tickets aus Zeiteinträgen nachladen."
                     FontSize="12"
                     Opacity="0.75"
                     TextWrapping="Wrap" />

          <Grid ColumnDefinitions="*,*,*"
                ColumnSpacing="12"
                RowDefinitions="Auto,Auto">
            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
              <TextBlock Classes="filter-label" Text="Zugewiesen" />
              <ComboBox Classes="filter-field"
                        ItemsSource="{Binding AssigneeFilterOptions}"
                        SelectedItem="{Binding SelectedAssigneeFilter}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
              <TextBlock Classes="filter-label" Text="Status" />
              <ComboBox Classes="filter-field"
                        ItemsSource="{Binding StatusFilterOptions}"
                        SelectedItem="{Binding SelectedStatusFilter}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4" IsEnabled="{Binding IsLastBookedUntilFilterEnabled}">
              <TextBlock Classes="filter-label" Text="Zuletzt gebucht bis" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Classes="secondary filter-date-picker">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <materialIcons:MaterialIcon Grid.Column="0"
                                              Kind="CalendarMonth"
                                              Width="16"
                                              Height="16"
                                              VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding LastBookedUntilLabel}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                  </Grid>
                  <Button.Flyout>
                    <Flyout Placement="Bottom">
                      <Calendar SelectedDate="{Binding LastBookedUntil}"
                                DisplayDate="{Binding CalendarDisplayDate, Mode=TwoWay}"
                                IsTodayHighlighted="True"
                                FirstDayOfWeek="Monday"
                                SelectedDatesChanged="OnLastBookedUntilCalendarSelectedDatesChanged" />
                    </Flyout>
                  </Button.Flyout>
                </Button>
                <Button Grid.Column="1"
                        Classes="ghost compact"
                        ToolTip.Tip="Filter zurücksetzen"
                        IsVisible="{Binding HasLastBookedUntilFilter}"
                        Command="{Binding ClearLastBookedUntilFilterCommand}">
                  <materialIcons:MaterialIcon Kind="Close" Width="16" Height="16" />
                </Button>
              </Grid>
            </StackPanel>
          </Grid>

          <CheckBox Content="Zusätzlich Tickets aus Zeiteinträgen laden (letzte 12 Monate, langsamer)"
                    IsChecked="{Binding IncludeTimeEntryTickets}" />
        </StackPanel>
      </Border>

      <Button Classes="primary"
              Command="{Binding LoadTicketsCommand}"
              Content="{materialIcons:MaterialIconTextExt Kind=Refresh, Text=Tickets laden}" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Width="180" PlaceholderText="Ticket-ID" Text="{Binding TicketIdToAdd}" />
        <Button Classes="secondary"
                Command="{Binding AddTicketByIdCommand}"
                Content="{materialIcons:MaterialIconTextExt Kind=Plus, Text=Ticket per ID hinzufügen}" />
      </StackPanel>

      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
    </StackPanel>

    <ListBox Grid.Row="1"
             Margin="24,0,24,24"
             ItemsSource="{Binding Tickets}"
             SelectedItem="{Binding SelectedTicket}">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:TicketListItemViewModel">
          <Border Classes="ticket-item"
                  Classes.favorite="{Binding IsFavorite}"
                  Padding="8"
                  Margin="0,0,0,8">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
              <StackPanel Grid.Row="0"
                          Grid.Column="0"
                          Orientation="Horizontal"
                          Spacing="8">
                <TextBlock Text="{Binding Ticket.Id, StringFormat=#\{0\}}" FontWeight="Bold" />
                <Border Classes="favorite-badge" IsVisible="{Binding IsFavorite}">
                  <TextBlock Classes="favorite-badge-text" Text="Favorit" />
                </Border>
              </StackPanel>

              <StackPanel Grid.Row="0"
                          Grid.Column="1"
                          Grid.RowSpan="4"
                          VerticalAlignment="Top"
                          Spacing="4">
                <Button Classes="ghost"
                        ToolTip.Tip="In Redmine öffnen"
                        Command="{Binding $parent[UserControl].DataContext.OpenTicketInBrowserCommand}"
                        CommandParameter="{Binding .}">
                  <materialIcons:MaterialIcon Kind="OpenInNew" Width="18" Height="18" />
                </Button>
                <Button Classes="ghost"
                        ToolTip.Tip="Favorit setzen/entfernen"
                        Command="{Binding $parent[UserControl].DataContext.ToggleFavoriteForTicketCommand}"
                        CommandParameter="{Binding .}">
                  <Panel>
                    <materialIcons:MaterialIcon Classes="favorite-star active"
                                                  Kind="Star"
                                                  IsVisible="{Binding IsFavorite}" />
                    <materialIcons:MaterialIcon Classes="favorite-star inactive"
                                                  Kind="StarOutline"
                                                  IsVisible="{Binding !IsFavorite}" />
                  </Panel>
                </Button>
              </StackPanel>

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Text="{Binding Ticket.Subject}"
                         TextWrapping="Wrap"
                         Margin="0,0,8,0" />
              <TextBlock Grid.Row="2"
                         Grid.Column="0"
                         Classes="ticket-meta"
                         Text="{Binding DetailsLine}"
                         Margin="0,4,8,0" />
              <StackPanel Grid.Row="3"
                          Grid.Column="0"
                          Orientation="Horizontal"
                          Spacing="16"
                          Margin="0,4,8,0">
                <TextBlock Classes="ticket-extra"
                           Text="{Binding DueDateLabel}"
                           IsVisible="{Binding HasDueDate}" />
                <TextBlock Classes="ticket-extra"
                           Text="{Binding LastTimeEntryLabel}" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
