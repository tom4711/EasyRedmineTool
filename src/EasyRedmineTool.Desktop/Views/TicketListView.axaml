<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    x:Class="EasyRedmineTool.Desktop.Views.TicketListView"
    x:DataType="vm:TicketListViewModel">

  <StackPanel Margin="24" Spacing="12">
    <TextBlock Text="Meine offenen Tickets" FontSize="22" FontWeight="Bold" />

    <Button Content="Tickets laden" Command="{Binding LoadTicketsCommand}" />

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBox Width="180" Watermark="Ticket-ID" Text="{Binding TicketIdToAdd}" />
      <Button Content="Ticket per ID hinzufügen" Command="{Binding AddTicketByIdCommand}" />
    </StackPanel>

    <Button Content="Favorit für ausgewähltes Ticket umschalten" Command="{Binding ToggleSelectedFavoriteCommand}" />
    <TextBlock Text="{Binding IsSelectedFavorite, StringFormat=Ausgewähltes Ticket Favorit: {0}}" />

    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />

    <ListBox ItemsSource="{Binding Tickets}" SelectedItem="{Binding SelectedTicket}" Height="300">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Padding="8" Margin="0,0,0,8">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding Id, StringFormat=#\{0\}}" FontWeight="Bold" />
              <TextBlock Text="{Binding Subject}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding Project.Name, StringFormat=Projekt: {0}}" />
              <TextBlock Text="{Binding Status.Name, StringFormat=Status: {0}}" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </StackPanel>
</UserControl>
