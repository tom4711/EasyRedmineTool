<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasyRedmineTool.Desktop.ViewModels"
        xmlns:views="using:EasyRedmineTool.Desktop.Views"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="EasyRedmineTool.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-icon.png"
        Title="{Binding WindowTitle}">

  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <Border Grid.Row="0"
            Background="{DynamicResource CardBackgroundBrush}"
            Padding="24,16,24,12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8">
          <Button Classes="nav"
                  Command="{Binding OpenTicketListCommand}"
                  Content="{materialIcons:MaterialIconTextExt Kind=ClipboardListOutline, Text=Tickets}" />
          <Button Classes="nav"
                  Command="{Binding OpenTimeEntriesCommand}"
                  Content="{materialIcons:MaterialIconTextExt Kind=ClockOutline, Text=Zeiteinträge}" />
          <Button Classes="nav"
                  Command="{Binding OpenSeriesBookingCommand}"
                  Content="{materialIcons:MaterialIconTextExt Kind=CalendarSync, Text=Serienbuchung}" />
          <Button Classes="nav"
                  Command="{Binding OpenWeeklySummaryCommand}"
                  Content="{materialIcons:MaterialIconTextExt Kind=ChartTimelineVariant, Text=Auswertung}" />
          <Button Classes="nav"
                  Command="{Binding OpenSettingsCommand}"
                  Content="{materialIcons:MaterialIconTextExt Kind=CogOutline, Text=Einstellungen}" />
          <Button Classes="nav"
                  Command="{Binding OpenAboutCommand}"
                  Content="{materialIcons:MaterialIconTextExt Kind=InformationOutline, Text=Info}" />
        </StackPanel>

        <ToggleButton Grid.Column="1"
                      Classes="theme-toggle"
                      IsChecked="{Binding IsDarkMode}"
                      ToolTip.Tip="Design-Modus wechseln">
          <Panel>
            <materialIcons:MaterialIcon Kind="WeatherNight"
                                        IsVisible="{Binding !IsDarkMode}" />
            <materialIcons:MaterialIcon Kind="WhiteBalanceSunny"
                                        IsVisible="{Binding IsDarkMode}" />
          </Panel>
        </ToggleButton>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            IsVisible="{Binding IsUpdateAvailable}"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,10">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
          <materialIcons:MaterialIcon Kind="ArrowUpCircleOutline"
                                      Width="18"
                                      Height="18"
                                      VerticalAlignment="Center" />
          <TextBlock Text="{Binding UpdateBannerMessage}"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap" />
        </StackPanel>
        <Button Grid.Column="1"
                Classes="secondary compact"
                Content="Release öffnen"
                Command="{Binding OpenUpdateReleaseCommand}" />
        <Button Grid.Column="2"
                Classes="ghost compact"
                ToolTip.Tip="Hinweis ausblenden"
                AutomationProperties.Name="Hinweis ausblenden"
                Command="{Binding DismissUpdateNoticeCommand}">
          <materialIcons:MaterialIcon Kind="Close" Width="16" Height="16" />
        </Button>
      </Grid>
    </Border>

    <Separator Grid.Row="2" />

    <Panel Grid.Row="3" ClipToBounds="True">
      <Grid IsVisible="{Binding IsSettingsVisible}">
        <views:SettingsView DataContext="{Binding SettingsViewModel}" />
      </Grid>

      <Grid IsVisible="{Binding IsTicketListVisible}">
        <views:TicketListView DataContext="{Binding TicketListViewModel}" />
      </Grid>

      <Grid IsVisible="{Binding IsTimeEntriesVisible}">
        <views:TimeEntriesView DataContext="{Binding TimeEntriesViewModel}" />
      </Grid>

      <Grid IsVisible="{Binding IsWeeklySummaryVisible}">
        <views:WeeklySummaryView DataContext="{Binding WeeklySummaryViewModel}" />
      </Grid>

      <Grid IsVisible="{Binding IsSeriesBookingVisible}">
        <views:SeriesBookingView DataContext="{Binding SeriesBookingViewModel}" />
      </Grid>

      <Grid IsVisible="{Binding IsAboutVisible}">
        <views:AboutView DataContext="{Binding AboutViewModel}" />
      </Grid>
    </Panel>
  </Grid>

</Window>
