<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    x:Class="EasyRedmineTool.Desktop.Views.SettingsView"
    x:DataType="vm:SettingsViewModel">

  <StackPanel Margin="24" Spacing="12">
    <TextBlock Text="Einstellungen" FontSize="22" FontWeight="Bold" />

    <TextBlock Text="Base URL" />
    <TextBox Text="{Binding BaseUrl}" PlaceholderText="https://projects.hawe.com/" />

    <TextBlock Text="API Key" />
    <TextBox Text="{Binding ApiKey}" PasswordChar="*" />

    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Classes="primary"
              Content="Speichern"
              Command="{Binding SaveSettingsCommand}" />
      <Button Classes="secondary"
              Content="Verbindung testen"
              Command="{Binding TestConnectionCommand}" />
    </StackPanel>

    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
  </StackPanel>
</UserControl>
