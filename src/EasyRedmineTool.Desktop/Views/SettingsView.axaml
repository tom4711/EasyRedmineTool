<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="EasyRedmineTool.Desktop.Views.SettingsView"
    x:DataType="vm:SettingsViewModel">

  <StackPanel Margin="24" Spacing="12">
    <TextBlock Text="Einstellungen" FontSize="22" FontWeight="Bold" />

    <TextBlock Text="Basis-URL" />
    <TextBox Text="{Binding BaseUrl}" PlaceholderText="https://projects.hawe.com/" />

    <TextBlock Text="API-Schlüssel" />
    <TextBox Text="{Binding ApiKey}" PasswordChar="*" />
    <TextBlock Text="{Binding ApiKeyStorageHint}"
               TextWrapping="Wrap"
               FontSize="12"
               Opacity="0.75" />

    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Classes="primary"
              Command="{Binding SaveSettingsCommand}"
              Content="{materialIcons:MaterialIconTextExt Kind=ContentSave, Text=Speichern}" />
      <Button Classes="secondary"
              Command="{Binding TestConnectionCommand}"
              Content="{materialIcons:MaterialIconTextExt Kind=LinkVariant, Text=Verbindung testen}" />
    </StackPanel>

    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
  </StackPanel>
</UserControl>
