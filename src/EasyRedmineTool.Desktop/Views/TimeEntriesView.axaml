<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="EasyRedmineTool.Desktop.Views.TimeEntriesView"
    x:DataType="vm:TimeEntriesViewModel">
  <UserControl.Styles>
    <Style Selector="Border.time-entry-card">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="20" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Opacity" Value="0.85" />
    </Style>
    <Style Selector="Border.favorite-booking-row">
      <Setter Property="Background" Value="{DynamicResource FavoriteRowBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource FavoriteRowBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="Border.favorite-booking-row.focused">
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="TextBlock.favorite-row-id">
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="MinWidth" Value="56" />
    </Style>
    <Style Selector="TextBlock.favorite-row-subject">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="MaxLines" Value="1" />
    </Style>
    <Style Selector="TextBlock.favorite-row-project">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.65" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="MaxLines" Value="1" />
    </Style>
    <Style Selector="TextBlock.today-booked-caption">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Opacity" Value="0.75" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.today-booked-value">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="TextBlock.inline-field-label">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.7" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="TextBox.hours-input">
      <Setter Property="Width" Value="64" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="MaxHeight" Value="32" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.hours-input /template/ Border#PART_ContentPresenterBorder">
      <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="ComboBox.row-field">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="MaxHeight" Value="32" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="TextBox.row-field">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="MaxHeight" Value="32" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.row-field /template/ Border#PART_ContentPresenterBorder">
      <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="Button.row-date-picker">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style Selector="Border.today-entry-row">
      <Setter Property="Background" Value="{DynamicResource FavoriteRowBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource FavoriteRowBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="Border.today-entry-delete-warning">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="TextBlock.today-entry-meta">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>
    <Style Selector="Expander.today-overview">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander.today-overview /template/ ToggleButton#PART_toggle">
      <Setter Property="Padding" Value="0" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Margin="24,24,24,12" Spacing="8">
      <TextBlock Text="Zeiteinträge" FontSize="22" FontWeight="Bold" />
      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Opacity="0.85" />

      <Border Classes="time-entry-card"
              Margin="0,8,0,0"
              Padding="16"
              HorizontalAlignment="Stretch">
        <Expander Classes="today-overview"
                  IsExpanded="{Binding IsTodayOverviewExpanded}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch">
          <Expander.Header>
            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                  VerticalAlignment="Center"
                  ColumnSpacing="12">
              <TextBlock Grid.Column="0"
                         Classes="today-booked-caption"
                         Text="Heute gebucht"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Classes="today-booked-value"
                         Text="{Binding TodayBookedHoursDisplay}"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="2"
                         Text="{Binding TodayEntriesSummary}"
                         FontSize="12"
                         Opacity="0.7"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Margin="0,0,8,0" />
            </Grid>
          </Expander.Header>

          <StackPanel Spacing="8" Margin="0,8,0,0">
            <TextBlock Text="Einträge können bearbeitet oder mit Bestätigung gelöscht werden."
                       FontSize="12"
                       Opacity="0.75"
                       TextWrapping="Wrap" />

            <ItemsControl ItemsSource="{Binding TodayTimeEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TodayTimeEntryRowViewModel">
                  <Border Classes="today-entry-row"
                          Margin="0,0,0,8">
                    <StackPanel Spacing="10">
                      <Grid ColumnDefinitions="*,Auto"
                            IsVisible="{Binding !IsDeleteConfirmationVisible}">
                        <StackPanel Grid.Column="0" Spacing="4">
                          <TextBlock Text="{Binding TicketLabel}"
                                     FontWeight="SemiBold"
                                     FontSize="13"
                                     TextWrapping="Wrap" />
                          <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Classes="today-entry-meta"
                                       Text="{Binding HoursDisplay}" />
                            <TextBlock Classes="today-entry-meta"
                                       Text="{Binding ActivityName}" />
                          </StackPanel>
                          <TextBlock Classes="today-entry-meta"
                                     Text="{Binding CommentsDisplay}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Top"
                                    IsVisible="{Binding !IsEditing}">
                          <Button Classes="ghost compact"
                                  ToolTip.Tip="Bearbeiten"
                                  Command="{Binding BeginEditCommand}"
                                  IsEnabled="{Binding !IsBusy}">
                            <materialIcons:MaterialIcon Kind="Pencil" Width="16" Height="16" />
                          </Button>
                          <Button Classes="ghost compact"
                                  ToolTip.Tip="Löschen"
                                  Command="{Binding RequestDeleteCommand}"
                                  IsEnabled="{Binding !IsBusy}">
                            <materialIcons:MaterialIcon Kind="Delete" Width="16" Height="16" />
                          </Button>
                        </StackPanel>
                      </Grid>

                      <StackPanel Spacing="10"
                                  IsVisible="{Binding IsEditing}">
                        <Grid ColumnDefinitions="72,12,*,12,Auto"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="4">
                          <TextBlock Grid.Row="0"
                                     Grid.Column="0"
                                     Classes="inline-field-label"
                                     Text="Stunden" />
                          <TextBox Grid.Row="1"
                                   Grid.Column="0"
                                   Classes="hours-input"
                                   Text="{Binding Hours}" />

                          <TextBlock Grid.Row="0"
                                     Grid.Column="2"
                                     Classes="inline-field-label"
                                     Text="Aktivität" />
                          <ComboBox Grid.Row="1"
                                    Grid.Column="2"
                                    Classes="row-field"
                                    HorizontalAlignment="Stretch"
                                    ItemsSource="{Binding Activities}"
                                    SelectedItem="{Binding SelectedActivity}">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>

                          <StackPanel Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Grid.Column="4"
                                      Orientation="Horizontal"
                                      Spacing="4"
                                      VerticalAlignment="Center">
                            <Button Classes="secondary compact"
                                    Command="{Binding CancelEditCommand}"
                                    Content="Abbrechen" />
                            <Button Classes="primary compact"
                                    Command="{Binding SaveEditCommand}"
                                    IsEnabled="{Binding !IsBusy}"
                                    Content="Speichern" />
                          </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                          <TextBlock Classes="inline-field-label" Text="Kommentar" />
                          <TextBox Classes="row-field"
                                   Text="{Binding Comments}"
                                   PlaceholderText="optional" />
                        </StackPanel>

                        <StackPanel Spacing="8" IsVisible="{Binding HasCustomFields}">
                          <ItemsControl ItemsSource="{Binding CustomFields}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="vm:TimeEntryCustomFieldRowViewModel">
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="12" Margin="0,0,0,8">
                                  <TextBlock Grid.Column="0"
                                             Classes="inline-field-label"
                                             Text="{Binding Name}"
                                             TextWrapping="Wrap" />
                                  <ComboBox Grid.Column="1"
                                            IsVisible="{Binding HasCompactPossibleValues}"
                                            ItemsSource="{Binding PossibleValues}"
                                            SelectedItem="{Binding SelectedValue}"
                                            HorizontalAlignment="Stretch"
                                            PlaceholderText="Bitte wählen …" />
                                  <AutoCompleteBox Grid.Column="1"
                                                   IsVisible="{Binding IsSearchableList}"
                                                   ItemsSource="{Binding PossibleValues}"
                                                   Text="{Binding Value}"
                                                   PlaceholderText="Suchen …"
                                                   MinimumPrefixLength="0"
                                                   HorizontalAlignment="Stretch" />
                                  <TextBox Grid.Column="1"
                                           IsVisible="{Binding !HasPossibleValues}"
                                           Text="{Binding Value}"
                                           Classes="row-field"
                                           HorizontalAlignment="Stretch"
                                           PlaceholderText="Wert eingeben …" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </StackPanel>

                      <Border Classes="today-entry-delete-warning"
                              IsVisible="{Binding IsDeleteConfirmationVisible}">
                        <StackPanel Spacing="10">
                          <TextBlock Text="Diesen Zeiteintrag wirklich löschen?"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{Binding TicketLabel}"
                                     FontSize="12"
                                     Opacity="0.85"
                                     TextWrapping="Wrap" />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="secondary compact"
                                    Command="{Binding CancelDeleteCommand}"
                                    Content="Abbrechen" />
                            <Button Classes="primary compact"
                                    Command="{Binding ConfirmDeleteCommand}"
                                    IsEnabled="{Binding !IsBusy}"
                                    Content="Löschen" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Keine Zeiteinträge für heute."
                       FontSize="12"
                       Opacity="0.7"
                       IsVisible="{Binding !HasTodayTimeEntries}" />
          </StackPanel>
        </Expander>
      </Border>
    </StackPanel>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
      <Border Margin="24,0,24,24"
              Classes="time-entry-card"
              HorizontalAlignment="Stretch">
        <StackPanel Spacing="16">
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0"
                       Classes="section-title"
                       Text="{Binding BookingSectionTitle}"
                       VerticalAlignment="Center" />
            <Border Grid.Column="1"
                    Classes="filter-segment-group"
                    VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Classes="filter-segment"
                        Classes.active="{Binding ShowFavoritesOnly}"
                        Content="Favoriten"
                        Command="{Binding ShowFavoritesOnlyViewCommand}" />
                <Button Classes="filter-segment"
                        Classes.active="{Binding !ShowFavoritesOnly}"
                        Content="Alle"
                        Command="{Binding ShowAllTicketsViewCommand}" />
              </StackPanel>
            </Border>
            <Button Grid.Column="2"
                    Classes="ghost compact"
                    ToolTip.Tip="Liste neu laden"
                    Command="{Binding ReloadFavoritesCommand}">
              <materialIcons:MaterialIcon Kind="Refresh" Width="18" Height="18" />
            </Button>
          </Grid>

          <StackPanel Spacing="4">
            <TextBox Text="{Binding FavoriteFilterText}"
                     PlaceholderText="{Binding SearchPlaceholder}" />
            <TextBlock Text="{Binding ListScopeSummary}"
                       FontSize="12"
                       Opacity="0.75" />
          </StackPanel>

          <ItemsControl ItemsSource="{Binding FilteredFavoriteRows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:FavoriteTimeEntryRowViewModel">
                <Border Classes="favorite-booking-row"
                        Classes.focused="{Binding IsFocused}"
                        Margin="0,0,0,10">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                      <TextBlock Grid.Column="0"
                                 Classes="favorite-row-id"
                                 Text="{Binding Ticket.Id, StringFormat=#\{0\}}" />
                      <StackPanel Grid.Column="1" Spacing="1">
                        <TextBlock Classes="favorite-row-subject" Text="{Binding Ticket.Subject}" />
                        <TextBlock Classes="favorite-row-project" Text="{Binding Ticket.Project.Name}" />
                      </StackPanel>
                      <Button Grid.Column="2"
                              Classes="ghost compact"
                              ToolTip.Tip="In Redmine öffnen"
                              Command="{Binding OpenInBrowserCommand}">
                        <materialIcons:MaterialIcon Kind="OpenInNew" Width="18" Height="18" />
                      </Button>
                    </Grid>

                    <Grid ColumnDefinitions="72,12,*,12,160,12,*,12,Auto"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="4">
                      <TextBlock Grid.Row="0"
                                 Grid.Column="0"
                                 Classes="inline-field-label"
                                 Text="Stunden" />
                      <TextBox Grid.Row="1"
                               Grid.Column="0"
                               Classes="hours-input"
                               Text="{Binding Hours}"
                               PlaceholderText="1.5" />

                      <TextBlock Grid.Row="0"
                                 Grid.Column="2"
                                 Classes="inline-field-label"
                                 Text="Aktivität" />
                      <ComboBox Grid.Row="1"
                                Grid.Column="2"
                                Classes="row-field"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding Activities}"
                                SelectedItem="{Binding SelectedActivity}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>

                      <TextBlock Grid.Row="0"
                                 Grid.Column="4"
                                 Classes="inline-field-label"
                                 Text="Datum" />
                      <StackPanel Grid.Row="1"
                                  Grid.Column="4"
                                  Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <Button Classes="secondary compact"
                                  Content="Heute"
                                  Command="{Binding SetSpentOnTodayCommand}" />
                          <Button Classes="secondary compact"
                                  Content="Gestern"
                                  Command="{Binding SetSpentOnYesterdayCommand}" />
                        </StackPanel>
                        <Button Classes="secondary row-date-picker"
                                HorizontalContentAlignment="Left">
                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <materialIcons:MaterialIcon Grid.Column="0"
                                                        Kind="CalendarMonth"
                                                        Width="16"
                                                        Height="16"
                                                        VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedDateLabel}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                          </Grid>
                          <Button.Flyout>
                            <Flyout Placement="Bottom">
                              <Calendar SelectedDate="{Binding SpentOn}"
                                        DisplayDate="{Binding CalendarDisplayDate, Mode=TwoWay}"
                                        IsTodayHighlighted="True"
                                        FirstDayOfWeek="Monday"
                                        SelectedDatesChanged="OnRowCalendarSelectedDatesChanged" />
                            </Flyout>
                          </Button.Flyout>
                        </Button>
                      </StackPanel>

                      <TextBlock Grid.Row="0"
                                 Grid.Column="6"
                                 Classes="inline-field-label"
                                 Text="Kommentar" />
                      <TextBox Grid.Row="1"
                               Grid.Column="6"
                               Classes="row-field"
                               Text="{Binding Comments}"
                               PlaceholderText="optional" />

                      <Button Grid.Row="0"
                              Grid.RowSpan="2"
                              Grid.Column="8"
                              Classes="primary"
                              VerticalAlignment="Center"
                              MinWidth="96"
                              Command="{Binding CreateTimeEntryCommand}"
                              Content="{materialIcons:MaterialIconTextExt Kind=Plus, Text=Buchen}" />
                    </Grid>

                    <StackPanel Spacing="8" IsVisible="{Binding HasCustomFields}">
                      <ItemsControl ItemsSource="{Binding CustomFields}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="vm:TimeEntryCustomFieldRowViewModel">
                            <Grid ColumnDefinitions="140,*" ColumnSpacing="12" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0"
                                         Classes="inline-field-label"
                                         Text="{Binding Name}"
                                         TextWrapping="Wrap" />
                              <ComboBox Grid.Column="1"
                                        IsVisible="{Binding HasCompactPossibleValues}"
                                        ItemsSource="{Binding PossibleValues}"
                                        SelectedItem="{Binding SelectedValue}"
                                        HorizontalAlignment="Stretch"
                                        PlaceholderText="Bitte wählen …" />
                              <AutoCompleteBox Grid.Column="1"
                                               IsVisible="{Binding IsSearchableList}"
                                               ItemsSource="{Binding PossibleValues}"
                                               Text="{Binding Value}"
                                               PlaceholderText="Suchen …"
                                               MinimumPrefixLength="0"
                                               HorizontalAlignment="Stretch" />
                              <TextBox Grid.Column="1"
                                       IsVisible="{Binding !HasPossibleValues}"
                                       Text="{Binding Value}"
                                       Classes="row-field"
                                       HorizontalAlignment="Stretch"
                                       PlaceholderText="Wert eingeben …" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </ScrollViewer>
  </Grid>
</UserControl>
