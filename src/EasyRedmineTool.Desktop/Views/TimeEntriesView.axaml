<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    xmlns:models="using:EasyRedmineTool.Core.Models.Tickets"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="EasyRedmineTool.Desktop.Views.TimeEntriesView"
    x:DataType="vm:TimeEntriesViewModel">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="TimeEntryCardBorderBrush" Color="#E0E0E0" />
          <SolidColorBrush x:Key="TimeEntryCardBackgroundBrush" Color="#FAFAFA" />
          <SolidColorBrush x:Key="FavoriteRowBackgroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="FavoriteRowBorderBrush" Color="#D1D5DB" />
          <SolidColorBrush x:Key="FavoriteRowHoverBackgroundBrush" Color="#F3F4F6" />
          <SolidColorBrush x:Key="FavoriteRowSelectedBackgroundBrush" Color="#BFDBFE" />
          <SolidColorBrush x:Key="FavoriteRowSelectedBorderBrush" Color="#1D4ED8" />
          <SolidColorBrush x:Key="FavoriteRowSelectedAccentBrush" Color="#2563EB" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="TimeEntryCardBorderBrush" Color="#525252" />
          <SolidColorBrush x:Key="TimeEntryCardBackgroundBrush" Color="#2A2A2A" />
          <SolidColorBrush x:Key="FavoriteRowBackgroundBrush" Color="#1F1F1F" />
          <SolidColorBrush x:Key="FavoriteRowBorderBrush" Color="#525252" />
          <SolidColorBrush x:Key="FavoriteRowHoverBackgroundBrush" Color="#333333" />
          <SolidColorBrush x:Key="FavoriteRowSelectedBackgroundBrush" Color="#1E3A8A" />
          <SolidColorBrush x:Key="FavoriteRowSelectedBorderBrush" Color="#93C5FD" />
          <SolidColorBrush x:Key="FavoriteRowSelectedAccentBrush" Color="#60A5FA" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.time-entry-card">
      <Setter Property="Background" Value="{DynamicResource TimeEntryCardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TimeEntryCardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="20" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Opacity" Value="0.85" />
    </Style>
    <Style Selector="ListBox.favorite-picker">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.favorite-picker ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.favorite-picker ListBoxItem:pointerover:not(:selected) Border.favorite-row">
      <Setter Property="Background" Value="{DynamicResource FavoriteRowHoverBackgroundBrush}" />
    </Style>
    <Style Selector="ListBox.favorite-picker ListBoxItem:selected Border.favorite-row">
      <Setter Property="Background" Value="{DynamicResource FavoriteRowSelectedBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource FavoriteRowSelectedBorderBrush}" />
    </Style>
    <Style Selector="ListBox.favorite-picker ListBoxItem:selected Border.favorite-row-accent">
      <Setter Property="Background" Value="{DynamicResource FavoriteRowSelectedAccentBrush}" />
    </Style>
    <Style Selector="ListBox.favorite-picker ListBoxItem:selected TextBlock.favorite-row-id">
      <Setter Property="Foreground" Value="{DynamicResource FavoriteRowSelectedBorderBrush}" />
    </Style>
    <Style Selector="ListBox.favorite-picker ListBoxItem:selected TextBlock.favorite-row-subject">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ListBox.favorite-picker ListBoxItem:selected materialIcons|MaterialIcon.favorite-row-check">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="ListBox.favorite-picker ListBoxItem:not(:selected) materialIcons|MaterialIcon.favorite-row-check">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="Border.favorite-row">
      <Setter Property="Background" Value="{DynamicResource FavoriteRowBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource FavoriteRowBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Height" Value="52" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.favorite-row-accent">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Width" Value="6" />
      <Setter Property="CornerRadius" Value="8,0,0,8" />
      <Setter Property="Margin" Value="-1" />
    </Style>
    <Style Selector="materialIcons|MaterialIcon.favorite-row-check">
      <Setter Property="Kind" Value="CheckCircle" />
      <Setter Property="Width" Value="20" />
      <Setter Property="Height" Value="20" />
      <Setter Property="Foreground" Value="{DynamicResource FavoriteRowSelectedBorderBrush}" />
    </Style>
    <Style Selector="TextBlock.favorite-row-id">
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="MinWidth" Value="56" />
    </Style>
    <Style Selector="TextBlock.favorite-row-subject">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="MaxLines" Value="1" />
    </Style>
    <Style Selector="TextBlock.favorite-row-project">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Opacity" Value="0.65" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="MaxLines" Value="1" />
    </Style>
    <Style Selector="Button.date-picker-button">
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="MinWidth" Value="240" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">
    <Grid Grid.Row="0" Margin="24,24,24,8" ColumnDefinitions="*,Auto">
      <StackPanel Grid.Column="0" Spacing="4">
        <TextBlock Text="Zeiteinträge" FontSize="22" FontWeight="Bold" />
        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Opacity="0.85" />
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Text="{Binding TodayBookedHoursLabel}"
                 FontWeight="SemiBold"
                 VerticalAlignment="Top"
                 Opacity="0.9" />
    </Grid>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
      <Border Margin="24,0,24,24"
              Classes="time-entry-card"
              HorizontalAlignment="Stretch">
        <StackPanel Spacing="16">
          <TextBlock Classes="section-title" Text="Neuer Zeiteintrag" />

          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Grid.Column="0"
                         Classes="field-label"
                         Text="Favoriten-Ticket"
                         FontWeight="SemiBold" />
              <Button Grid.Column="1"
                      Classes="ghost compact"
                      ToolTip.Tip="Ausgewähltes Ticket in Redmine öffnen"
                      Command="{Binding OpenSelectedTicketInBrowserCommand}">
                <materialIcons:MaterialIcon Kind="OpenInNew" Width="18" Height="18" />
              </Button>
              <Button Grid.Column="2"
                      Classes="ghost compact"
                      ToolTip.Tip="Favoriten neu laden"
                      Command="{Binding ReloadFavoritesCommand}">
                <materialIcons:MaterialIcon Kind="Refresh" Width="18" Height="18" />
              </Button>
            </Grid>

            <TextBox Text="{Binding FavoriteFilterText}"
                     PlaceholderText="Ticket suchen (Nr., Betreff, Projekt) …" />

            <Border BorderThickness="1"
                    BorderBrush="{DynamicResource TimeEntryCardBorderBrush}"
                    CornerRadius="8"
                    ClipToBounds="True">
              <ScrollViewer MaxHeight="240"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <ListBox Classes="favorite-picker"
                         Margin="8"
                         ItemsSource="{Binding FilteredFavoriteTickets}"
                         SelectedItem="{Binding SelectedFavoriteTicket}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:IssueDto">
                      <Border Classes="favorite-row">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                              Margin="12,0,12,0">
                          <Border Grid.Column="0" Classes="favorite-row-accent" />
                          <TextBlock Grid.Column="1"
                                     Classes="favorite-row-id"
                                     Text="{Binding Id, StringFormat=#\{0\}}" />
                          <StackPanel Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Margin="8,0,8,0"
                                      Spacing="1">
                            <TextBlock Classes="favorite-row-subject" Text="{Binding Subject}" />
                            <TextBlock Classes="favorite-row-project" Text="{Binding Project.Name}" />
                          </StackPanel>
                          <materialIcons:MaterialIcon Grid.Column="3"
                                                      Classes="favorite-row-check"
                                                      VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </ScrollViewer>
            </Border>
          </StackPanel>

          <Grid ColumnDefinitions="*,12,*"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                RowSpacing="8">
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Classes="field-label"
                       Text="Stunden" />
            <TextBox Grid.Row="1"
                     Grid.Column="0"
                     Text="{Binding Hours}"
                     PlaceholderText="z. B. 1.5" />

            <TextBlock Grid.Row="0"
                       Grid.Column="2"
                       Classes="field-label"
                       Text="Aktivität" />
            <ComboBox Grid.Row="1"
                      Grid.Column="2"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding Activities}"
                      SelectedItem="{Binding SelectedActivity}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       Classes="field-label"
                       Text="Kommentar"
                       Margin="0,4,0,0" />
            <TextBox Grid.Row="3"
                     Grid.Column="0"
                     Grid.ColumnSpan="3"
                     Text="{Binding Comments}"
                     MinHeight="96"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     PlaceholderText="Optional" />

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       Classes="field-label"
                       Text="Datum"
                       FontWeight="SemiBold"
                       Margin="0,4,0,0" />

            <StackPanel Grid.Row="5"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        Spacing="8">
              <Button Classes="secondary compact"
                      Content="Heute"
                      Command="{Binding SetSpentOnTodayCommand}" />
              <Button Classes="secondary compact"
                      Content="Gestern"
                      Command="{Binding SetSpentOnYesterdayCommand}" />
              <Button x:Name="DatePickerButton"
                      Classes="secondary date-picker-button"
                      HorizontalContentAlignment="Left">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                  <materialIcons:MaterialIcon Grid.Column="0"
                                              Kind="CalendarMonth"
                                              Width="18"
                                              Height="18"
                                              VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding SelectedDateLabel}"
                             VerticalAlignment="Center" />
                </Grid>
                <Button.Flyout>
                  <Flyout Placement="Bottom">
                    <Calendar SelectedDate="{Binding SpentOn}"
                              DisplayDate="{Binding CalendarDisplayDate, Mode=TwoWay}"
                              IsTodayHighlighted="True"
                              FirstDayOfWeek="Monday"
                              SelectedDatesChanged="OnCalendarSelectedDatesChanged" />
                  </Flyout>
                </Button.Flyout>
              </Button>
            </StackPanel>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="secondary"
                    Command="{Binding RepeatLastEntryCommand}"
                    Content="{materialIcons:MaterialIconTextExt Kind=ContentCopy, Text=Letzten Eintrag wiederholen}" />
          </StackPanel>

          <Button Classes="primary stretch"
                  Command="{Binding CreateTimeEntryCommand}"
                  Content="{materialIcons:MaterialIconTextExt Kind=Plus, Text=Zeiteintrag erstellen}" />
        </StackPanel>
      </Border>
    </ScrollViewer>
  </Grid>
</UserControl>
