<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EasyRedmineTool.Core.ViewModels"
    xmlns:models="using:EasyRedmineTool.Core.Models.TimeEntries"
    x:Class="EasyRedmineTool.Desktop.Views.TimeEntriesView"
    x:DataType="vm:TimeEntriesViewModel">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="TimeEntryCardBorderBrush" Color="#E0E0E0" />
          <SolidColorBrush x:Key="TimeEntryCardBackgroundBrush" Color="#FAFAFA" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="TimeEntryCardBorderBrush" Color="#525252" />
          <SolidColorBrush x:Key="TimeEntryCardBackgroundBrush" Color="#2A2A2A" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.time-entry-card">
      <Setter Property="Background" Value="{DynamicResource TimeEntryCardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TimeEntryCardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Opacity" Value="0.85" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Margin="24,24,24,8" Spacing="4">
      <TextBlock Text="Zeiteinträge" FontSize="22" FontWeight="Bold" />
      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Opacity="0.85" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
      <Grid Margin="24,0,24,24"
            ColumnDefinitions="*,16,*"
            RowDefinitions="Auto">
        <Border Grid.Column="0" Classes="time-entry-card">
          <StackPanel Spacing="14">
            <TextBlock Classes="section-title" Text="Neuer Zeiteintrag" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Grid.Column="0"
                         Classes="field-label"
                         Text="Favoriten-Ticket"
                         FontWeight="SemiBold" />
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="6">
                <Button Classes="secondary compact"
                        Content="Favoriten"
                        Command="{Binding ReloadFavoritesCommand}" />
                <Button Classes="secondary compact"
                        Content="Aktivitäten"
                        Command="{Binding ReloadActivitiesCommand}" />
              </StackPanel>
            </Grid>

            <ListBox ItemsSource="{Binding FavoriteTickets}"
                     SelectedItem="{Binding SelectedFavoriteTicket}"
                     MinHeight="100"
                     MaxHeight="140">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Id, StringFormat=#\{0\}}" FontWeight="Bold" />
                    <TextBlock Text="{Binding Subject}" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Grid ColumnDefinitions="110,*"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="10"
                  ColumnSpacing="12">
              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Classes="field-label"
                         Text="Stunden" />
              <TextBox Grid.Row="0"
                       Grid.Column="1"
                       Text="{Binding Hours}"
                       PlaceholderText="z. B. 1.5" />

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Classes="field-label"
                         Text="Aktivität" />
              <ComboBox Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Activities}"
                        SelectedItem="{Binding SelectedActivity}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBlock Grid.Row="2"
                         Grid.Column="0"
                         Classes="field-label"
                         Text="Kommentar"
                         VerticalAlignment="Top"
                         Margin="0,4,0,0" />
              <TextBox Grid.Row="2"
                       Grid.Column="1"
                       Text="{Binding Comments}"
                       MinHeight="64"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       PlaceholderText="Optional" />
            </Grid>

            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Classes="field-label"
                           Text="Datum"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Classes="secondary compact"
                        Content="Heute"
                        Command="{Binding SetSpentOnTodayCommand}" />
                <Button Grid.Column="2"
                        Classes="secondary compact"
                        Content="Gestern"
                        Command="{Binding SetSpentOnYesterdayCommand}" />
              </Grid>

              <TextBlock Text="{Binding SelectedDateLabel}" Opacity="0.85" />

              <Border HorizontalAlignment="Center"
                      Padding="4"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource TimeEntryCardBorderBrush}"
                      CornerRadius="6">
                <Calendar SelectedDate="{Binding SpentOn}"
                          DisplayDate="{Binding CalendarDisplayDate, Mode=TwoWay}"
                          IsTodayHighlighted="True"
                          FirstDayOfWeek="Monday" />
              </Border>
            </StackPanel>

            <Button Classes="primary stretch"
                    Content="Zeiteintrag erstellen"
                    Command="{Binding CreateTimeEntryCommand}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Classes="time-entry-card">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Grid.Column="0"
                         Classes="section-title"
                         Text="Wochenübersicht"
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Classes="secondary compact"
                      Content="Aktualisieren"
                      Command="{Binding ReloadWeeklySummaryCommand}" />
            </Grid>

            <TextBlock Text="{Binding CurrentQuarterLabel}" Opacity="0.85" TextWrapping="Wrap" />
            <TextBlock Text="{Binding WeeklyTotalHours, StringFormat=Gesamtstunden im Zeitraum: {0}}" />

            <ListBox ItemsSource="{Binding WeeklyHours}" MinHeight="220">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:WeeklyHoursDto">
                  <StackPanel Spacing="4" Margin="0,0,0,8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding Label}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Hours, StringFormat={}{0} h}"
                                 FontWeight="Bold" />
                    </Grid>
                    <ProgressBar Minimum="0"
                                 Maximum="{Binding $parent[UserControl].DataContext.MaxWeeklyHours}"
                                 Value="{Binding Hours}"
                                 Height="10" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>
      </Grid>
    </ScrollViewer>
  </Grid>
</UserControl>
