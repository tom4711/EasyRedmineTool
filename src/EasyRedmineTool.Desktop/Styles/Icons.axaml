<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="AppIconForegroundBrush" Color="#374151" />
      <SolidColorBrush x:Key="AppIconOnAccentForegroundBrush" Color="#FFFFFF" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="AppIconForegroundBrush" Color="#F3F4F6" />
      <SolidColorBrush x:Key="AppIconOnAccentForegroundBrush" Color="#FFFFFF" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
